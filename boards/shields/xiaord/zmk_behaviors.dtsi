/*
 * SPDX-License-Identifier: MIT
 *
 * Input processor mapping INPUT_EV_ZMK_BEHAVIORS codes to ZMK system/BT behaviors.
 * Include this file from your keyboard overlay and add &zmk_behaviors to
 * the input-processors list of the touchpad_listener (or any input-listener
 * connected to the xiaord virtual-key source).
 *
 * Required Kconfig:
 *   CONFIG_ZMK_BLE=y           — &bt * behaviors
 *   CONFIG_ZMK_PM_SOFT_OFF=y   — &soft_off
 *   CONFIG_ZMK_STUDIO=y        — &studio_unlock
 *
 * Note: INPUT_VIRTUAL_ZMK_BT_CLR_0..11 codes are defined in input_codes.h
 * but have no bindings here. Per-profile CLR requires SEL+CLR (two actions),
 * which cannot be expressed as a single input-processor entry. Define them
 * via macros in your keyboard overlay if needed.
 */

#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/xiaord/input_codes.h>

/ {
    zmk_behaviors: zmk_behaviors {
        compatible = "zmk,input-processor-behaviors";
        #input-processor-cells = <0>;
        type = <INPUT_EV_ZMK_BEHAVIORS>;
        codes = <
            INPUT_VIRTUAL_ZMK_SYS_RESET     INPUT_VIRTUAL_ZMK_BOOTLOADER
            INPUT_VIRTUAL_ZMK_SOFT_OFF       INPUT_VIRTUAL_ZMK_STUDIO_UNLOCK
            INPUT_VIRTUAL_ZMK_BT_CLR        INPUT_VIRTUAL_ZMK_BT_CLR_ALL
            INPUT_VIRTUAL_ZMK_BT_NXT        INPUT_VIRTUAL_ZMK_BT_PRV
            INPUT_VIRTUAL_ZMK_BT_SEL_0      INPUT_VIRTUAL_ZMK_BT_SEL_1
            INPUT_VIRTUAL_ZMK_BT_SEL_2      INPUT_VIRTUAL_ZMK_BT_SEL_3
            INPUT_VIRTUAL_ZMK_BT_SEL_4      INPUT_VIRTUAL_ZMK_BT_SEL_5
            INPUT_VIRTUAL_ZMK_BT_SEL_6      INPUT_VIRTUAL_ZMK_BT_SEL_7
            INPUT_VIRTUAL_ZMK_BT_SEL_8      INPUT_VIRTUAL_ZMK_BT_SEL_9
            INPUT_VIRTUAL_ZMK_BT_SEL_10     INPUT_VIRTUAL_ZMK_BT_SEL_11
            INPUT_VIRTUAL_ZMK_BT_DISC_0     INPUT_VIRTUAL_ZMK_BT_DISC_1
            INPUT_VIRTUAL_ZMK_BT_DISC_2     INPUT_VIRTUAL_ZMK_BT_DISC_3
            INPUT_VIRTUAL_ZMK_BT_DISC_4     INPUT_VIRTUAL_ZMK_BT_DISC_5
            INPUT_VIRTUAL_ZMK_BT_DISC_6     INPUT_VIRTUAL_ZMK_BT_DISC_7
            INPUT_VIRTUAL_ZMK_BT_DISC_8     INPUT_VIRTUAL_ZMK_BT_DISC_9
            INPUT_VIRTUAL_ZMK_BT_DISC_10    INPUT_VIRTUAL_ZMK_BT_DISC_11
            INPUT_VIRTUAL_SYM_UPLOAD
            INPUT_VIRTUAL_SYM_MINUS
        >;
        bindings = <
            &sys_reset     &bootloader
            &soft_off      &studio_unlock
            &bt BT_CLR     &bt BT_CLR_ALL
            &bt BT_NXT     &bt BT_PRV
            &bt BT_SEL 0   &bt BT_SEL 1
            &bt BT_SEL 2   &bt BT_SEL 3
            &bt BT_SEL 4   &bt BT_SEL 5
            &bt BT_SEL 6   &bt BT_SEL 7
            &bt BT_SEL 8   &bt BT_SEL 9
            &bt BT_SEL 10  &bt BT_SEL 11
            &bt BT_DISC 0  &bt BT_DISC 1
            &bt BT_DISC 2  &bt BT_DISC 3
            &bt BT_DISC 4  &bt BT_DISC 5
            &bt BT_DISC 6  &bt BT_DISC 7
            &bt BT_DISC 8  &bt BT_DISC 9
            &bt BT_DISC 10 &bt BT_DISC 11
            &bootloader
            &kp N0
        >;
    };
};
