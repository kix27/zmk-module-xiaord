config INPUT_CHSC6X_CUSTOM
	bool "CHSC6X custom input driver"
	default n
	depends on I2C && INPUT
	help
	  Enable custom driver for CHSC6X touchpad controller.
	  This is a customized version for the xiaord round display.

if INPUT_CHSC6X_CUSTOM

config INPUT_CHSC6X_CUSTOM_SENSITIVITY_X10
	int "Cursor sensitivity (x10)"
	default 20
	help
	  Cursor sensitivity multiplied by 10. Default 20 means 2.0f.

config INPUT_CHSC6X_CUSTOM_MIN_BTN_INTERVAL
	int "Minimum button interval (ms)"
	default 20
	help
	  Minimum interval between button press and release.

config INPUT_CHSC6X_CUSTOM_LONG_PRESS_TIME
	int "Long press time for right click (ms)"
	default 600

config INPUT_CHSC6X_CUSTOM_SWIPE_THRESHOLD
	int "Swipe movement threshold (pixels)"
	default 10
	help
	  Movement pixels to distinguish between a tap and a swipe.

config INPUT_CHSC6X_CUSTOM_INERTIA
	bool "Enable inertial cursor"
	default y
	help
	  Continue cursor movement after flicking.


if INPUT_CHSC6X_CUSTOM_INERTIA

config INPUT_CHSC6X_CUSTOM_INERTIA_INTERVAL
	int "Inertia update interval (ms)"
	default 20
	help
	  How often to update cursor position during inertia.

config INPUT_CHSC6X_CUSTOM_INERTIA_THRESHOLD_X100
	int "Inertia start velocity threshold (x100)"
	default 80
	help
	  Threshold to start inertia. Default 80 means 0.8f.

config INPUT_CHSC6X_CUSTOM_INERTIA_DECAY_X100
	int "Inertia decay rate (x100)"
	default 95
	help
	  Velocity decay per interval. Default 95 means 0.95 (5% slow down).

endif # INPUT_CHSC6X_CUSTOM_INERTIA
endif # INPUT_CHSC6X_CUSTOM

config ZMK_VIRTUAL_POINTER
	bool "Virtual touch-to-pointer input converter"
	default y
	depends on DT_HAS_ZMK_VIRTUAL_POINTER_ENABLED

if ZMK_VIRTUAL_POINTER

config ZMK_VIRTUAL_POINTER_SENSITIVITY_X10
	int "Cursor sensitivity (x10)"
	default 20
	help
	  Cursor sensitivity multiplied by 10. Default 20 means 2.0x.

config ZMK_VIRTUAL_POINTER_MIN_BTN_INTERVAL
	int "Minimum button press/release interval (ms)"
	default 20

config ZMK_VIRTUAL_POINTER_LONG_PRESS_TIME
	int "Long press time for right click (ms)"
	default 600

config ZMK_VIRTUAL_POINTER_SWIPE_THRESHOLD
	int "Manhattan distance threshold to distinguish tap from swipe"
	default 10

config ZMK_VIRTUAL_POINTER_INERTIA
	bool "Enable inertial cursor after flick"
	default y

if ZMK_VIRTUAL_POINTER_INERTIA

config ZMK_VIRTUAL_POINTER_INERTIA_INTERVAL
	int "Inertia update interval (ms)"
	default 20

config ZMK_VIRTUAL_POINTER_INERTIA_THRESHOLD_X100
	int "Inertia start velocity threshold (x100)"
	default 80
	help
	  Minimum velocity to trigger inertia. Default 80 means 0.80.

config ZMK_VIRTUAL_POINTER_INERTIA_DECAY_X100
	int "Inertia velocity decay per interval (x100)"
	default 95
	help
	  Fraction of velocity retained each interval. Default 95 means 0.95 (5% slowdown).

endif # ZMK_VIRTUAL_POINTER_INERTIA
endif # ZMK_VIRTUAL_POINTER

config ZMK_INPUT_PROCESSOR_CODE_CANCELLER
	bool "Code Canceller Input Processor"
	default y
	depends on DT_HAS_ZMK_INPUT_PROCESSOR_CODE_CANCELLER_ENABLED
	help
	  Suppress (cancel) specific input event codes, preventing them from
	  being processed further down the input processor chain.